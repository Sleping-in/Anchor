    "Yes, guide me" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "نعم، أرشدني"
          }
        }
      }
    },
    "Yes, voice conversations require an internet connection. If you're offline, Anchor switches to a text-only mode so you can still check in." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "نعم، تتطلب المحادثات الصوتية اتصالاً بالإنترنت. إذا كنت غير متصل، ينتقل مرساة إلى وضع النص فقط ليتيح لك تسجيل الوصول."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Yes, voice conversations require an internet connection. If you're offline, Anchor switches to a text-only mode so you can still check in."
          }
        }
      }
    },
    "Yes. Go to Settings → Privacy & Data → Delete All My Data. You can also delete individual sessions from the History screen by swiping left." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "نعم. اذهب إلى الإعدادات → الخصوصية والبيانات → حذف جميع بياناتي. يمكنك أيضاً حذف جلسات فردية من شاشة السجل بالسحب لليسار."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Yes. Go to Settings → Privacy & Data → Delete All My Data. You can also delete individual sessions from the History screen by swiping left."
          }
        }
      }
    },
    "Yes. Go to Settings → Privacy & Data → Export My Data, or use the menu in History. Your data is exported as a JSON file that you can save or share." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "نعم. اذهب إلى الإعدادات → الخصوصية والبيانات → تصدير بياناتي، أو استخدم القائمة في السجل. يتم تصدير بياناتك كملف JSON يمكنك حفظه أو مشاركته."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Yes. Go to Settings → Privacy & Data → Export My Data, or use the menu in History. Your data is exported as a JSON file that you can save or share."
          }
        }
      }
