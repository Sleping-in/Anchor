    "We are not liable for any decisions or actions taken based on conversations with Anchor." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لا نتحمل مسؤولية أي قرارات أو إجراءات يتم اتخاذها بناءً على المحادثات مع مرساة."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "We are not liable for any decisions or actions taken based on conversations with Anchor."
          }
        }
      }
    },
    "We collect minimal data:\n• Conversation history (stored locally)\n• User preferences (stored locally)\n• On-device voice stress signal (used to tune responses, not diagnostic)\n• Anonymous usage analytics (optional)" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "نجمع أقل قدر من البيانات:\n• سجل المحادثات (مخزن محلياً)\n• تفضيلات المستخدم (مخزنة محلياً)\n• إشارة إجهاد الصوت على الجهاز (تُستخدم لتحسين الاستجابات، ليست تشخيصية)\n• تحليلات استخدام مجهولة (اختيارية)"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "We collect minimal data:\n• Conversation history (stored locally)\n• User preferences (stored locally)\n• On-device voice stress signal (used to tune responses, not diagnostic)\n• Anonymous usage analytics (optional)"
          }
        }
      }
    },
    "We updated Anchor and had to reset local data. A backup of your previous sessions was saved on this device." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قمنا بتحديث مرساة واضطررنا لإعادة تعيين البيانات المحلية. تم حفظ نسخة احتياطية من جلساتك السابقة على هذا الجهاز."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "We updated Anchor and had to reset local data. A backup of your previous sessions was saved on this device."
          }
        }
      }
    },
    "We use AI services for conversation processing. Only anonymous conversation text is sent to our AI provider, never any identifying information." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "نستخدم خدمات الذكاء الاصطناعي لمعالجة المحادثات. يتم إرسال نص المحادثة المجهول فقط إلى مزود الذكاء الاصطناعي، ولا يتم إرسال أي معلومات تعريفية أبداً."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "We use AI services for conversation processing. Only anonymous conversation text is sent to our AI provider, never any identifying information."
          }
        }
      }
    },
